.page {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  margin-bottom: 48rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.slider-wrap {
  width: 686rpx;
  height: 320rpx;
  margin: 0 auto;
}

.selected {
  margin-top: 48rpx;
  text-align: center;
}

.selected-emoji {
  display: block;
  font-size: 72rpx;
  line-height: 1.2;
}

.selected-name {
  display: block;
  margin-top: 16rpx;
  font-size: 32rpx;
}

.hint {
  display: block;
  margin-top: 24rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
}
